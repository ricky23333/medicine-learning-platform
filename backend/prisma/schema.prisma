  jobGroup      String    @db.VarChar(64)
  invokeTarget  String    @db.VarChar(500)
  jobMessage    String?   @db.VarChar(500)
  status        String?   @default("0") @db.Char(1)
  exceptionInfo String?   @default("") @db.VarChar(2000)
