  postName   String    @db.VarChar(50)
  postSort   Int
  status     String    @db.Char(1)
  createBy   String?   @default("") @db.VarChar(64)
  createTime DateTime? @db.DateTime(0)
  updateBy   String?   @default("") @db.VarChar(64)
  updateTime DateTime? @db.DateTime(0)
