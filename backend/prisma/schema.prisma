/// 馆/博物馆表
model Museum {
  museumId    Int        @id @default(autoincrement())
  museumName  String     @db.VarChar(100)
  museumCode  String     @unique @db.VarChar(50)
  description String?    @db.VarChar(500)
  status      String     @default("0") @db.Char(1)
  enabled     Boolean    @default(true)
  sort        Int        @default(0)
  createBy    String     @default("") @db.VarChar(64)
  createTime  DateTime?
  updateBy    String?    @default("") @db.VarChar(64)
  updateTime  DateTime?
  categories  Category[]
  exams       Exam[]
  specimens   Specimen[]

  @@map("museum")
}

/// 标本分类表
model Category {
  categoryId   Int        @id @default(autoincrement())
  museumId     Int
  parentId     Int?
  categoryName String     @db.VarChar(50)
  categoryCode String     @db.VarChar(50)
  sort         Int        @default(0)
  status       String     @default("0") @db.Char(1)
  createBy     String     @default("") @db.VarChar(64)
  createTime   DateTime?
  updateBy     String?    @default("") @db.VarChar(64)
  updateTime   DateTime?
  description  String?    @db.VarChar(500)
  museum       Museum     @relation(fields: [museumId], references: [museumId])
  specimens    Specimen[]

  @@index([museumId], map: "category_museumId_fkey")
  @@map("category")
}

/// 标本表
model Specimen {
  specimenId    Int             @id @default(autoincrement())
  museumId      Int
  categoryId    Int
  specimenName  String          @db.VarChar(100)
  remark        String?         @db.Text
  status        String          @default("0") @db.Char(1)
  createBy      String          @default("") @db.VarChar(64)
  createTime    DateTime?
  updateBy      String?         @default("") @db.VarChar(64)
  updateTime    DateTime?
  examQuestions ExamQuestion[]
  category      Category        @relation(fields: [categoryId], references: [categoryId])
  museum        Museum          @relation(fields: [museumId], references: [museumId])
  images        SpecimenImage[]

  @@index([categoryId], map: "specimen_categoryId_fkey")
  @@index([museumId], map: "specimen_museumId_fkey")
  @@map("specimen")
}

/// 标本图片表
model SpecimenImage {
  imageId      Int       @id @default(autoincrement())
  specimenId   Int
  imageUrl     String    @db.VarChar(255)
  isCover      Boolean   @default(false)
  sort         Int       @default(0)
  createBy     String    @default("") @db.VarChar(64)
  createTime   DateTime?
  auditStatus  String    @default("0") @db.Char(1)
  auditBy      String?   @db.VarChar(64)
  auditTime    DateTime?
  auditRemark  String?   @db.VarChar(255)
  thumbnailUrl String?   @db.VarChar(255)
  specimen     Specimen  @relation(fields: [specimenId], references: [specimenId])

  @@index([specimenId], map: "specimen_image_specimenId_fkey")
  @@map("specimen_image")
}

/// 小程序用户扩展表
model AppUser {
  id             Int       @id @default(autoincrement())
  userId         Int       @unique
  userType       String    @default("student") @db.VarChar(20)
  realName       String    @db.VarChar(50)
  phone          String    @db.VarChar(11)
  institution    String    @db.VarChar(100)
  majorGrade     String?   @db.VarChar(50)
  studentNo      String?   @db.VarChar(30)
  identity       String?   @db.VarChar(18)
  contact        String?   @db.VarChar(50)
  vipStatus      String    @default("0") @db.Char(1)
  vipApplyTime   DateTime?
  vipApproveTime DateTime?
  vipApproveBy   String?   @db.VarChar(64)
  regStatus      String    @default("0") @db.Char(1)
  regApplyTime   DateTime?
  regApproveTime DateTime?
  regApproveBy   String?   @db.VarChar(64)
  createTime     DateTime?
  openid         String?   @unique @db.VarChar(50)
  user           SysUser   @relation(fields: [userId], references: [userId])

  @@map("app_user")
}

/// 考试记录表
model Exam {
  examId         Int            @id @default(autoincrement())
  userId         Int
  museumId       Int?
  score          Int            @default(0)
  totalQuestions Int            @default(0)
  correctCount   Int            @default(0)
  examTime       DateTime       @default(now())
  status         String         @default("0") @db.Char(1)
  museum         Museum?        @relation(fields: [museumId], references: [museumId])
  questions      ExamQuestion[]

  @@index([museumId], map: "exam_museumId_fkey")
  @@map("exam")
}

/// 考试题目表
model ExamQuestion {
  id         Int      @id @default(autoincrement())
  examId     Int
  specimenId Int
  imageId    Int
  userAnswer String?  @db.VarChar(100)
  isCorrect  Boolean  @default(false)
  sort       Int
  exam       Exam     @relation(fields: [examId], references: [examId])
  specimen   Specimen @relation(fields: [specimenId], references: [specimenId])

  @@index([examId], map: "exam_question_examId_fkey")
  @@index([specimenId], map: "exam_question_specimenId_fkey")
  @@map("exam_question")
}

/// 系统访问统计表
model AppVisitLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  ip        String?  @db.VarChar(50)
  visitTime DateTime @default(now())
  path      String?  @db.VarChar(255)

  @@map("app_visit_log")
}

/// 标本访问记录表
model SpecimenVisitLog {
  id         Int      @id @default(autoincrement())
  specimenId Int
  userId     Int?
  visitTime  DateTime @default(now())

  @@map("specimen_visit_log")
}

/// 用户反馈建议表
model AppFeedback {
  id        Int       @id @default(autoincrement())
  userId    Int?
  userType  String?   @db.VarChar(20)   // 用户类型：student/teacher
  content   String    @db.Text         // 反馈内容
  contact   String?   @db.VarChar(100) // 联系方式
  images    String?   @db.Text         // 图片JSON数组
  status    String    @default("0")    @db.Char(1) // 处理状态：0待处理 1已处理
  remark    String?   @db.VarChar(500) // 处理备注
  handleBy  String?   @db.VarChar(64)  // 处理人
  handleTime DateTime?                 // 处理时间
  createBy  String    @default("")     @db.VarChar(64)
  createTime DateTime?                @db.DateTime(0)
  updateBy  String?   @default("")    @db.VarChar(64)
  updateTime DateTime?

  @@map("app_feedback")
}
