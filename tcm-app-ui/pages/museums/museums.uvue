  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.museum-card {
  display: flex;
  align-items: center;
  gap: 16px;
  background: #ffffff;
  border-radius: 16px;
  padding: 20px;
  box-shadow: 0 1px 6px rgba(0, 0, 0, 0.08);
  flex-direction: row;
}

.museum-icon {
  width: 48px;
  height: 48px;
  border-radius: 16px;
  background: #e8f5e9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  flex-shrink: 0;
}


.museum-content {
  flex: 1;
}

.museum-name {
  display: block;
  font-size: 15px;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 4px;
}

.museum-desc {
  display: block;
  font-size: 12px;
  color: #888;
  margin-bottom: 8px;
}

.museum-tags {
  display: flex;
  gap: 8px;
  flex-direction: row;
}

