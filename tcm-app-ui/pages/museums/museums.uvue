<template>
  <view class="museums-page">
    <!-- 导航栏 -->
    <view class="navbar">
      <text class="nav-back" @click="goBack">←</text>
      <text class="nav-title">标本馆</text>
    </view>

    <!-- 标本馆列表 -->
    <view class="museum-list">
      <view
        v-for="museum in museums"
        :key="museum.id"
        class="museum-card"
        @click="goCategories(museum)"
      >
        <view class="museum-icon">{{ museum.icon }}</view>
        <view class="museum-content">          
          <text class="museum-name">{{ museum.name }}</text>
          <text class="museum-desc">{{ museum.description.slice(0, 30) }}...</text>
          <view class="museum-tags">
            <text class="tag">{{ museum.categories.length }}个分类</text>
            <text class="tag-outline">{{ getSpecimenCount(museum.id) }}种标本</text>
          </view>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>

    <!-- 底部导航 -->
    <BottomTabBar activeTab="browse" />
  </view>
</template>

<script setup lang="uts">
import { computed } from 'vue'
import { useAppContext } from '@/context/AppContext.uts'
import BottomTabBar from '@/components/BottomTabBar/index.uvue'

const context = useAppContext()
const museums = computed(() => context.getMuseums())

function goBack() {
  uni.switchTab({ url: '/pages/home/home' })
}

function getSpecimenCount(museumId: string): number {
  return context.specimens.filter(s => s.museumId === museumId).length
}

function goCategories(museum: { id: string; name: string }) {
  uni.navigateTo({
    url: `/pages/museums/categories?museumId=${museum.id}&museumName=${encodeURIComponent(museum.name)}`,
  })
}
</script>

