	font-size: 14px;
	font-weight: 500;
	border: none;
	border-radius: 12px;
	margin-top: 8px;
}

.phone-hint {
	display: block;
	font-size: 11px;
	color: #999;
	margin-top: 4px;
	text-align: center;
}

/* 按钮 */
.btn-next {
	width: 100%;
	height: 48px;
	background: #2d6a4f;
	color: #ffffff;
	font-size: 15px;
	font-weight: 600;
	border: none;
	border-radius: 12px;
}

.btn-row {
	display: flex;
	gap: 12px;
}

.btn-prev {
	flex: 1;
	height: 48px;
	background: #f0f0f0;
	color: #666;
	font-size: 15px;
	font-weight: 500;
	border: none;
	border-radius: 12px;
}

.btn-submit {
	flex: 2;
	height: 48px;
	background: #2d6a4f;
	color: #ffffff;
	font-size: 15px;
	font-weight: 600;
	border: none;
	border-radius: 12px;
}

/* 结果页 */
.result-card {
	border-radius: 16px;
	padding: 32px 24px;
	text-align: center;
	margin-bottom: 24px;
}

.result-card.success {
	background: #e8f5e9;
}

.result-card.fail {
	background: #ffebee;
}

.result-icon {
	font-size: 48px;
	display: block;
	margin-bottom: 16px;
}

.result-card.success .result-icon {
	color: #4cd964;
}

.result-card.fail .result-icon {
	color: #dd524d;
}

.result-title {
	font-size: 18px;
	font-weight: 600;
	color: #333;
	display: block;
	margin-bottom: 8px;
}

.result-text {
	font-size: 13px;
	color: #666;
	line-height: 1.6;
	display: block;
}

.btn-back-login,
.btn-retry {
	width: 100%;
	height: 48px;
	background: #2d6a4f;
	color: #ffffff;
	font-size: 15px;
	font-weight: 600;
	border: none;
	border-radius: 12px;
}
</style>