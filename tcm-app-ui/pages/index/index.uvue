<template>
  <view class="index-page">
    <!-- 重定向到登录页或首页 -->
  </view>
</template>

<script setup lang="uts">
onLoad(() => {
  // 检查用户是否已同意协议
  const agreedToTerms = uni.getStorageSync('agreedToTerms')
  if (agreedToTerms) {
    // 已同意协议，跳转到首页
    uni.switchTab({ url: '/pages/home/home' })
  } else {
    // 未同意协议，显示登录页（协议弹窗）
    uni.redirectTo({ url: '/pages/login/login' })
  }
})
</script>

<style scoped>
.index-page {
  min-height: 100vh;
}
</style>