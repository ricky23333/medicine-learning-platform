  font-weight: 500;
  color: #2d6a4f;
  flex-shrink: 0;
}

.countdown-bar.urgent .countdown-text {
  color: #ef4444;
}

.countdown-progress {
  flex: 1;
  height: 4px;
  background: #c8e6c9;
  border-radius: 2px;
  overflow: hidden;
}

.countdown-bar.urgent .countdown-progress {
  background: #ffcdd2;
}

.countdown-progress-fill {
  height: 100%;
  background: #2d6a4f;
  border-radius: 2px;
  transition: width 1s linear;
}

