.countdown-bar {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 16px;
  background: #e8f5e9;
  flex-direction: row;
}

.countdown-bar.urgent {
  background: #ffebee;
}

.countdown-icon {
  font-size: 16px;
}

.countdown-text {
