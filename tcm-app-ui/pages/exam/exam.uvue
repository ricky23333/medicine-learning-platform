<template>
  <view class="exam-page">
    <!-- 进度条区域 -->
    <view class="progress-bar">
      <view class="progress-info">
        <text class="progress-text">第 {{ currentIndex + 1 }} / {{ totalQuestions }} 题</text>
      </view>
      <view class="progress-track">
        <view class="progress-fill" :style="{ width: `${((currentIndex + 1) / totalQuestions) * 100}%` }"></view>
      </view>
    </view>

    <!-- 倒计时区域 -->
    <view class="countdown-bar" :class="{ urgent: isUrgent }">
      <text class="countdown-icon">⏱</text>
      <text class="countdown-text">剩余时间：{{ formattedTime }}</text>
      <view class="countdown-progress">
        <view class="countdown-progress-fill" :style="{ width: `${remainingPercent}%` }"></view>
      </view>
    </view>

    <!-- 标本图片 -->
    <view class="image-area">
      <ImageViewer
        v-if="currentSpecimen && approvedImage"
        :src="approvedImage.url"
      />
      <view v-else class="placeholder">🔬</view>
    </view>

    <!-- 答案输入区域 -->
    <view class="answer-area">
      <text class="question-text">请填写此标本的名称：</text>
      <input
        v-model="answer"
        placeholder="填写标本名称..."
        class="answer-input"
        @focus="onFocus"
        @blur="onBlur"
      />
    </view>

    <!-- 底部导航 -->
    <view class="bottom-nav">
      <view
        class="nav-btn prev"
        :class="{ disabled: currentIndex === 0 }"
        @click="goPrev"
      >         
                <image class="nav-icon" src="/static/icons/pre.png" mode="aspectFit" />
        <text class="nav-text">上一题</text>
      </view>

      <view
        v-if="currentIndex < totalQuestions - 1"
        class="nav-btn next"
        @click="goNext"
      >
        <text class="nav-text">下一题</text>
         <image class="nav-icon" src="/static/icons/next.png" mode="aspectFit" />
      </view>
      <view
        v-else
        class="nav-btn submit"
        @click="confirmSubmit"
      >
        <text class="nav-text">提交答卷</text>
      </view>
    </view>

    <!-- 考试成绩弹窗 -->
    <view v-if="showResultModal" class="result-modal-mask">
      <view class="result-modal">
        <view class="result-header">
          <text class="result-title">考试完成</text>
        </view>
        <view class="result-body">
          <view class="score-circle">
            <text class="score">{{ lastExamRecord?.score || 0 }}</text>
            <text class="score-divider">/</text>
            <text class="total">{{ lastExamRecord?.totalQuestions || 0 }}</text>
          </view>
          <text class="grade-text">{{ gradeText }}</text>
          <text class="grade-percent">{{ gradePercent }}分</text>
        </view>
        <view class="result-footer">
          <view class="btn-close" @click="closeResultModal">关闭</view>
        </view>
      </view>
    </view>
  </view>
</template>

<script setup lang="uts">
import { ref, computed, onUnmounted } from 'vue'
import type { Specimen, SpecimenImage, ExamRecord } from '@/types/index.uts'
import { useAppContext } from '@/context/AppContext.uts'
import { getExamDuration } from '@/api/exam'
import ImageViewer from '@/components/ImageViewer/index.uvue'

const context = useAppContext()

const museumId = ref('')
const categoryIds = ref<string[]>([])
const examSpecimens = ref<Specimen[]>([])
const answers = ref<string[]>([])
const currentIndex = ref(0)
const isExamStarted = ref(false)
const showResultModal = ref(false)
const lastExamRecord = ref<ExamRecord | null>(null)

// 考试计时器状态
const remaining = ref(0)
const isRunning = ref(false)
const formattedTime = ref('00:00')
const isUrgent = ref(false)
const remainingPercent = ref(100)
let timerId: number | null = null

// 初始化考试计时器
async function initExamTimer() {
  const duration = await getExamDuration()
  remaining.value = duration
  formattedTime.value = formatTimeValue(duration)
  remainingPercent.value = 100

  timerId = setInterval(() => {
    if (remaining.value > 0) {
      remaining.value--
      formattedTime.value = formatTimeValue(remaining.value)
      remainingPercent.value = Math.round((remaining.value / duration) * 100)
      isUrgent.value = remaining.value <= 5 * 60

      if (remaining.value === 0) {
        clearInterval(timerId!)
        timerId = null
        autoSubmitExam()
      }
    }
  }, 1000)
}

// 格式化时间为 MM:SS
function formatTimeValue(seconds: number): string {
  const minutes = Math.floor(seconds / 60)
  const secs = seconds % 60
  return `${minutes.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`
}

// 停止计时器
function stopTimer() {
  if (timerId !== null) {
    clearInterval(timerId)
    timerId = null
  }
  isRunning.value = false
}

const totalQuestions = computed(() => examSpecimens.value.length)

const currentSpecimen = computed(() => examSpecimens.value[currentIndex.value])

const approvedImage = computed(() => {
  return currentSpecimen.value?.images.find(img => img.status === 'approved')
})

const answer = computed({
  get: () => answers.value[currentIndex.value] || '',
  set: (val) => {
    answers.value[currentIndex.value] = val
  },
})

// 评级文字
const gradeText = computed(() => {
  const pct = gradePercent.value
  if (pct >= 90) return '优秀'
  if (pct >= 75) return '良好'
  if (pct >= 60) return '及格'
  return '不及格'
})

// 评级百分比
const gradePercent = computed(() => {
  const record = lastExamRecord.value
  if (!record || record.totalQuestions === 0) return 0
  return Math.round((record.score / record.totalQuestions) * 100)
})

onLoad(async (options: any) => {
  if (options) {
    museumId.value = options.museumId || ''
    const catIds = options.categoryIds || ''
    categoryIds.value = catIds ? catIds.split(',').filter((s: string) => s) : []

    // 获取可用于考试的标本
    const pool = context.getApprovedSpecimens(
      museumId.value,
      categoryIds.value.length > 0 ? categoryIds.value : undefined
    )

    // 随机抽取最多20个
    const shuffled = [...pool].sort(() => Math.random() - 0.5).slice(0, Math.min(20, pool.length))
    examSpecimens.value = shuffled
    answers.value = new Array(shuffled.length).fill('')

    // 初始化并启动考试计时器
    await initExamTimer()
    isExamStarted.value = true
  }
})

onUnmounted(() => {
  // 清理计时器
  stopTimer()
})

function goPrev() {
  if (currentIndex.value > 0) {
    currentIndex.value--
  }
}

function goNext() {
  if (currentIndex.value < totalQuestions.value - 1) {
    currentIndex.value++
  }
}

function confirmSubmit() {
  uni.showModal({
    title: '确认',
    content: '确认提交答案？',
    success: (res) => {
      if (res.confirm) {
        submitExam()
      }
    },
  })
}

// 倒计时结束自动提交
function autoSubmitExam() {
  // 停止计时器
  stopTimer()
  // 提交考试
  submitExam()
}

function submitExam() {
  const museum = context.museums.find(m => m.id === museumId.value)
  const questions = examSpecimens.value.map((sp, i) => {
    const img = sp.images.find(img => img.status === 'approved')
    const userAnswer = answers.value[i]?.trim() || ''
    return {
      id: `q-${i}`,
      specimenId: sp.id,
      specimenName: sp.name,
      imageUrl: img?.url || '',
      correctAnswer: sp.name,
      userAnswer,
      isCorrect: userAnswer === sp.name,
    }
  })

  const score = questions.filter(q => q.isCorrect).length
  const record: ExamRecord = {
    id: `exam-${Date.now()}`,
    userId: context.currentUser?.id || '',
    userName: context.currentUser?.name || '',
    museumId: museumId.value,
    museumName: museum?.name || '',
    categoryIds: categoryIds.value,
    questions,
    score,
    totalQuestions: examSpecimens.value.length,
    submittedAt: new Date().toISOString(),
  }

  // 保存记录到 context
  context.submitExam(record)

  // 停止计时器
  stopTimer()

  // 显示成绩弹窗
  lastExamRecord.value = record
  showResultModal.value = true
}

function closeResultModal() {
  showResultModal.value = false
  // 返回考试选择页
  uni.reLaunch({
    url: '/pages/exam/exam-select',
  })
}

function onFocus(e: any) {
  // 聚焦时样式变化
}

function onBlur(e: any) {
  // 失焦时样式变化
}
</script>

<style scoped>
