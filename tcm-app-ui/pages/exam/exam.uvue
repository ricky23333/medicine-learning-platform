  display: flex;
  gap: 12px;
  padding: 12px 16px;
  border-top: 1px solid #f0f0f0;
  flex-direction: row;
}

.nav-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  height: 48px;
  border-radius: 16px;
  font-size: 14px;
  flex-direction: row;
  line-height: 48px;
}

