<template>
  <view class="history-detail-page">
    <!-- 导航栏 -->
    <view class="navbar">
      <text class="nav-back" @click="goBack">←</text>
      <text class="nav-title">考试详情</text>
    </view>

    <view class="content" v-if="record">
      <!-- 汇总卡片 -->
      <view class="summary-card">
        <view class="summary-info">
          <text class="museum-name">{{ record.museumName }}</text>
          <text class="record-time">{{ formatTime(record.submittedAt) }}</text>
        </view>
        <text class="score">{{ record.score }}/{{ record.totalQuestions }}</text>
      </view>

      <!-- 题目详情 -->
      <view
        v-for="(q, index) in record.questions"
        :key="q.id"
        class="question-card"
        :class="{ correct: q.isCorrect, wrong: !q.isCorrect }"
      >
        <text class="question-label">第{{ index + 1 }}题</text>
        <view class="answer-row">
          <text class="answer-label">正确答案：</text>
          <text class="answer-text">{{ q.correctAnswer }}</text>
        </view>
        <view class="answer-row">
          <text class="answer-label">作答：</text>
          <text class="answer-text" :class="{ wrong: !q.isCorrect }">
            {{ q.userAnswer || '（未作答）' }}
          </text>
          <text v-if="q.isCorrect" class="icon-correct">✓</text>
          <text v-else class="icon-wrong">✗</text>
        </view>
      </view>
    </view>

    <!-- 底部导航 -->
    <BottomTabBar activeTab="history" />
  </view>
</template>

<script setup lang="uts">
import { ref, computed } from 'vue'
import { useAppContext } from '@/context/AppContext.uts'
import BottomTabBar from '@/components/BottomTabBar/index.uvue'

const mockRecord = ref({
  id: 'mock-1',
  museumId: 'museum-1',
  museumName: '中药标本馆',
  userId: 'user-1',
  score: 85,
  totalQuestions: 100,
  submittedAt: '2026-05-10T14:30:00',
  questions: [
    { id: 'q1', correctAnswer: '人参', userAnswer: '人参', isCorrect: true },
    { id: 'q2', correctAnswer: '黄芪', userAnswer: '当归', isCorrect: false },
    { id: 'q3', correctAnswer: '甘草', userAnswer: '甘草', isCorrect: true },
  ],
})

const context = useAppContext()

const recordId = ref('')

const record = computed(() => {
  if (mockRecord.value) return mockRecord.value
  return context.getExamRecordById(recordId.value)
})

onLoad((options: any) => {
  if (options) {
    recordId.value = options.recordId || ''
  }
})

function goBack() {
  uni.navigateBack()
}

function formatTime(time: string): string {
  const date = new Date(time)
  return date.toLocaleString('zh-CN')
}
</script>

