  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #ffffff;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
  flex-direction: row;
}

.museum-name {
  display: block;
  font-size: 14px;
  font-weight: 500;
  color: #333;
  margin-bottom: 4px;
}

.record-time {
  display: block;
  font-size: 12px;
  color: #888;
}

.score {
  font-size: 24px;
  font-weight: 700;
  color: #2d6a4f;
}

.question-card {
  background: #ffffff;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
  border-left: 3px solid #52b788;
}

.question-card.wrong {
  border-left-color: #ef4444;
}

.question-label {
  display: block;
  font-size: 12px;
  color: #888;
  margin-bottom: 8px;
}

.answer-row {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-bottom: 4px;
  flex-direction: row;
}

