  font-size: 13px;
  color: #555;
}

.answer-text {
  font-size: 14px;
  font-weight: 500;
  color: #2d6a4f;
}

.answer-text.wrong {
  color: #ef4444;
}

.icon-correct {
  font-size: 14px;
  color: #2d6a4f;
  margin-left: 4px;
}

.icon-wrong {
  font-size: 14px;
  color: #ef4444;
  margin-left: 4px;
}
</style>