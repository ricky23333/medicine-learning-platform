.phone-frame {
  width: 375px;
  height: 667px;
  background: #fff;
  border-radius: 40px;
  overflow: hidden;
  box-shadow: 0 0 0 8px #1a1a1a, 0 0 0 12px #333;
  display: flex;
  flex-direction: column;
  position: relative;
}

/* 状态栏 */
.status-bar {
  height: 20px;
  padding: 0 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(180deg, #0d2818 0%, #1b3a2d 100%);
}

