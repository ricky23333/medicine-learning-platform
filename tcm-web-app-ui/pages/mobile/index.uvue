  padding: 12px;
  background: #f8faf8;
  border-radius: 10px;
}

.stat-value {
  font-size: 20px;
  font-weight: 700;
  color: $tcm-primary;
  display: block;
}

.stat-label {
  font-size: 10px;
  color: $tcm-text-grey;
  margin-top: 2px;
}

.quick-actions {
  display: flex;
  gap: 12px;
  padding: 16px 20px;
