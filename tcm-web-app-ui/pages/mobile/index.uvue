  font-size: 11px;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 2px;
}

.stats-cards {
  display: flex;
  gap: 12px;
  padding: 16px 20px;
  background: #fff;
}

.stat-card {
  flex: 1;
