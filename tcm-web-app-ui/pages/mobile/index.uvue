  background: #f0f4f0;
  border-radius: 16px;
  font-size: 13px;
  color: $tcm-text-dark;
}

/* ========== 首页 ========== */
.home-header {
  background: linear-gradient(135deg, #0d2818 0%, #1b3a2d 100%);
  padding: 20px;
  padding-top: 10px;
}

