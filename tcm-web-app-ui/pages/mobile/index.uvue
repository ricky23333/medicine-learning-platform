}

.action-icon {
  font-size: 24px;
}

.action-text {
  font-size: 12px;
  color: $tcm-text-dark;
}

.section {
  padding: 16px 20px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: $tcm-text-dark;
  margin-bottom: 12px;
}

.museum-list {
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
}

.museum-card {
  display: flex;
  align-items: center;
  padding: 16px;
  border-bottom: 1px solid #f0f0f0;

  &:last-child {
    border-bottom: none;
  }

  &:active {
