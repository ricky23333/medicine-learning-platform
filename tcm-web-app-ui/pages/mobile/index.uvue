}

.input {
  width: 100%;
  height: 44px;
  border: 1px solid #e0e0e0;
  border-radius: 10px;
  padding: 0 16px;
  margin-bottom: 16px;
  font-size: 14px;
}

.login-btn {
  width: 100%;
  height: 44px;
  background: linear-gradient(135deg, $tcm-primary, $tcm-secondary);
  border: none;
