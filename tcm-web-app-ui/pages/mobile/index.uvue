  flex: 1;
  overflow-y: auto;
  background: #f5f5f5;
}

/* 底部标签栏 */
.tab-bar {
  height: 50px;
  background: #fff;
  display: flex;
  border-top: 1px solid #e0e0e0;
  position: sticky;
  bottom: 0;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2px;

  &.active {
    .tab-icon, .tab-text {
      color: $tcm-primary;
    }
  }
}

.tab-icon {
  font-size: 20px;
  color: #aaa;
}

.tab-text {
