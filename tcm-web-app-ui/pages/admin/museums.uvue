  font-weight: 500;
  color: $tcm-text-dark;
  display: block;
  margin-bottom: 4px;
}

.category-desc {
  font-size: 12px;
  color: $tcm-text-grey;
  display: block;
  margin-bottom: 8px;
}

.category-count {
