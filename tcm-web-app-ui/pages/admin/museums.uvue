  right: 12px;
  display: flex;
  gap: 8px;
}

.action-btn {
  font-size: 14px;
  cursor: pointer;
  padding: 4px;

  &:active {
    opacity: 0.7;
  }
}

/* 新增分类卡片 */
.add-category-card {
  background: #fff;
  border: 2px dashed #d0d0d0;
  border-radius: 12px;
  padding: 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  cursor: pointer;

  &:active {
    border-color: $tcm-primary;
    background: #f8faf8;
  }
}

.add-icon {
  font-size: 24px;
